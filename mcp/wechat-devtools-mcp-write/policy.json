{
  "server": "wechat-devtools-mcp-write",
  "version": "0.1.0",
  "enabled": true,
  "activation": {
    "env": "WECHAT_WRITE_MCP_ENABLE",
    "required_value": "1"
  },
  "guardrails": {
    "require_explicit_enable": true,
    "require_confirmation_model": true,
    "allow_default_registration": false,
    "allow_tools_before_policy_review": true
  },
  "confirmation_contract": {
    "version": "write_confirm_v1",
    "callback_type": "client_confirmation",
    "required_fields": [
      "request_id",
      "action",
      "scope",
      "summary",
      "risk_level",
      "requires_explicit_yes",
      "expires_in_seconds"
    ],
    "risk_levels": [
      "low",
      "medium",
      "high"
    ],
    "default_ttl_seconds": 300
  },
  "proposed_tools": [
    {
      "name": "preview_project",
      "source": "Invoke-WechatPreview",
      "namespace": "deploy",
      "default_enabled": false,
      "requires_confirmation": true,
      "requires_validation": true,
      "project_scope": "D:\\卤味",
      "rollout_order": 1,
      "release_gate": {
        "tool_flag": "WECHAT_WRITE_TOOL_PREVIEW_ENABLE",
        "required_value": "1",
        "client_confirmation_required": true,
        "confirmation_contract_version": "write_confirm_v1"
      }
    },
    {
      "name": "deploy_cloud_function",
      "source": "Invoke-DeployCloudFunction",
      "namespace": "deploy",
      "default_enabled": false,
      "requires_confirmation": true,
      "requires_validation": true,
      "project_scope": "D:\\卤味",
      "rollout_order": 2
    },
    {
      "name": "deploy_changed_cloud_functions",
      "source": "Invoke-DeployChangedCloudFunctions",
      "namespace": "deploy",
      "default_enabled": false,
      "requires_confirmation": true,
      "requires_validation": true,
      "project_scope": "D:\\卤味",
      "rollout_order": 3
    },
    {
      "name": "safe_write_file",
      "source": "Invoke-SafeWrite",
      "namespace": "write",
      "default_enabled": false,
      "requires_confirmation": true,
      "requires_validation": true,
      "project_scope": "G:\\codex专属\\sandbox;G:\\codex测试;D:\\卤味 (future guarded only)",
      "rollout_order": 4
    }
  ],
  "allowed_namespaces": [
    "write",
    "deploy"
  ],
  "notes": [
    "Phase 3 first-tool rollout is active for preview_project under confirmation contract.",
    "Tool execution is still gated by explicit env flags and client confirmation.",
    "The proposed_tools list is a whitelist plan, not an active registration.",
    "preview_project may return confirmation_required but must not execute deploy directly."
  ]
}
