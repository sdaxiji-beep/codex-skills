    "mcp:installer-readiness": "powershell -ExecutionPolicy Bypass -File ./scripts/test-wechat-mcp-installer-readiness.ps1",
    "mcp:registration-guidance": "powershell -ExecutionPolicy Bypass -File ./scripts/test-wechat-mcp-registration-guidance.ps1"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "wechat",
    "miniprogram",
    "devtools"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "acorn": "^8.16.0",
    "miniprogram-automator": "^0.12.1",
    "zod": "^3.25.76"
  }
}
