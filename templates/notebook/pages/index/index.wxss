.container { padding: 20rpx; }
.header { display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 20rpx; }
.title { font-size: 36rpx; font-weight: bold; }
.add-btn { background: #07c160; color: #fff;
  font-size: 28rpx; padding: 10rpx 20rpx; }
.note-item { background: #fff; border-radius: 12rpx;
  padding: 24rpx; margin-bottom: 16rpx;
  display: flex; justify-content: space-between;
  align-items: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08); }
.note-title { font-size: 30rpx; flex: 1; }
.note-time { font-size: 24rpx; color: #999; margin: 0 16rpx; }
.delete-btn { color: #e64340; font-size: 26rpx; }
.empty { text-align: center; color: #999;
  margin-top: 100rpx; font-size: 28rpx; }
