<view class="container">
  <view class="header">
    <text class="title">我的记事本</text>
    <button bindtap="addNote" class="add-btn">+ 新建</button>
  </view>
  <view class="note-list">
    <view wx:for="{{notes}}" wx:key="id"
          class="note-item" bindtap="openNote"
          data-id="{{item.id}}">
      <text class="note-title">{{item.title}}</text>
      <text class="note-time">{{item.updatedAt}}</text>
      <text class="delete-btn" catchtap="deleteNote"
            data-id="{{item.id}}">删除</text>
    </view>
    <view wx:if="{{notes.length === 0}}" class="empty">
      <text>还没有记事，点击新建吧</text>
    </view>
  </view>
</view>
