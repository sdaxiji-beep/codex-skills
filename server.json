{
  "name": "wechat-devtools-control-mcp",
  "mcpName": "wechat-devtools-control-mcp",
  "version": "2.1.0-rc.1",
  "kind": "guarded-boundary-adapter",
  "entry": "scripts/wechat-mcp-server.mjs",
  "runtime": "node",
  "transport": "stdio",
  "tools": [
    "describe_contract",
    "describe_execution_profile",
    "run_task_pipeline",
    "validate_page_bundle",
    "apply_page_bundle",
    "validate_component_bundle",
    "apply_component_bundle",
    "validate_app_json_patch",
    "apply_app_json_patch"
  ],
  "resources": [
    "server_inventory",
    "read_order",
    "consumer_router",
    "path_conventions",
    "prompt_selection_guide",
    "task_map",
    "tool_selection_guide",
    "project_state",
    "validation_plan",
    "latest_diagnostics_metrics",
    "boundary_contract",
    "external_client_entrypoints",
    "release_package",
    "client_usage_guide",
    "inspector_quickstart",
    "surface_map",
    "registry_readiness",
    "installer_readiness",
    "distribution_quickstart",
    "registration_guidance"
  ],
  "prompts": [
    "generate_page_bundle",
    "generate_component_bundle",
    "repair_page_issue",
    "patch_app_routes"
  ],
  "writes_enabled": true,
  "deploy_enabled": false,
  "registration": {
    "default": false,
    "notes": "Keep registration client-specific and repo-relative. See MCP_INSPECTOR_QUICKSTART.md."
  }
}
