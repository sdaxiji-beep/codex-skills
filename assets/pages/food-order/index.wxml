    <text class="title">__FOOD_ORDER_TITLE__</text>
    <text class="subtitle">__FOOD_ORDER_SUBTITLE__</text>
  </view>
  <scroll-view class="category-strip" scroll-x="true" enable-flex="true">
    __FOOD_ORDER_CATEGORY_MARKUP__
