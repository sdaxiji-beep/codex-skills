{
  "task": {
    "id": "task-003-preview-v2",
    "title": "Run a preview-only cycle from the v2 release template",
    "type": "preview"
  },
  "target": {
    "files": [],
    "deploy": {
      "type": "preview",
      "functions": [],
      "version": "1.0.0"
    }
  },
  "requirements": {
    "description": "Run one preview-only task for D:\\luwei using the v2 template fields, and write a structured task record without modifying business code.",
    "acceptance": [
      "preview returns successfully",
      "no business code is modified",
      "a record file is written under artifacts\\records"
    ],
    "constraints": [
