{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wechat-component-bundle.schema.json",
  "title": "WeChat Component Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "component_name",
    "files"
  ],
  "properties": {
    "component_name": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "content"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^components\\/.+"
          },
          "content": {
            "type": "string"
          }
        }
      }
    }
  }
}
