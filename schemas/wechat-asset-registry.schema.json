{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wechat-asset-registry.schema.json",
  "title": "WeChat Asset Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "components"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "asset_registry_v1"
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/componentEntry"
      }
    },
    "page_templates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pageTemplateEntry"
      }
    }
  },
  "$defs": {
    "componentEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "family",
        "dependencies",
        "acceptance_rules",
        "entry_files"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "related_pages": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "entry_files": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "wxml",
            "js",
            "wxss",
            "json"
          ],
          "properties": {
            "wxml": {
              "type": "string",
              "pattern": "^assets/components/[a-z0-9-]+/index\\.wxml$"
            },
            "js": {
              "type": "string",
              "pattern": "^assets/components/[a-z0-9-]+/index\\.js$"
            },
            "wxss": {
              "type": "string",
              "pattern": "^assets/components/[a-z0-9-]+/index\\.wxss$"
            },
            "json": {
              "type": "string",
              "pattern": "^assets/components/[a-z0-9-]+/index\\.json$"
            }
          }
        },
        "acceptance_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "pageTemplateEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "family",
        "dependencies",
        "acceptance_rules",
        "entry_files"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "entry_files": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "wxml",
            "js",
            "wxss",
            "json"
          ],
          "properties": {
            "wxml": {
              "type": "string",
              "pattern": "^assets/pages/[a-z0-9-]+/index\\.wxml$"
            },
            "js": {
              "type": "string",
              "pattern": "^assets/pages/[a-z0-9-]+/index\\.js$"
            },
            "wxss": {
              "type": "string",
              "pattern": "^assets/pages/[a-z0-9-]+/index\\.wxss$"
            },
            "json": {
              "type": "string",
              "pattern": "^assets/pages/[a-z0-9-]+/index\\.json$"
            }
          }
        },
        "acceptance_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
